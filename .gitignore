# macOS
.DS_Store
._*

# Outputs - Verzeichnis behalten, Inhalte ignorieren
outputs/*
!outputs/.gitkeep

# Reference - Verzeichnis behalten, Inhalte ignorieren
reference/*
!reference/.gitkeep

# Sensible Dateien
*.env
.env.*
credentials.*
secrets.*
*.pem
*.key

# Python
.venv/
__pycache__/
*.pyc
*.egg-info/
build/
dist/

# Editor/IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Debug-Logs
/tmp/audiotranskript*.log
